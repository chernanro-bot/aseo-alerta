# Puerto del servidor
PORT=4000

# Supabase (obtener en supabase.com → Project Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # ⚠️ NUNCA exponer en el frontend

# Frontend URL (para CORS)
FRONTEND_URL=https://tu-app.netlify.app

# ─── Kapso.ai — WhatsApp Business API ──────────────────────
# Obtener en Kapso → API Keys
KAPSO_API_KEY=kapso_...
KAPSO_PHONE_ID=...

# Webhook de Kapso
# KAPSO_WEBHOOK_SECRET se obtiene al crear el webhook en Kapso → Webhooks
# Es el secret que Kapso usa para firmar los requests (X-Webhook-Signature)
KAPSO_WEBHOOK_SECRET=...
# Token de verificación: lo inventas tú, debe coincidir con lo configurado en Kapso
KAPSO_WEBHOOK_VERIFY_TOKEN=aseoalerta_webhook_2026

# ─── Toku — Pagos (https://toku.cl) ────────────────────────
TOKU_API_KEY=tk_...
TOKU_WEBHOOK_SECRET=whsec_...
TOKU_PLAN_ID=plan_...

# Clave interna para el cron job
CRON_SECRET=cambia_esto_por_algo_seguro_32chars

# Habilitar cron jobs en desarrollo
# ENABLE_CRON=true
